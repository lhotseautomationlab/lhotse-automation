# Environment variable examples (do NOT commit real secrets here)
# Name-only keys — fill these in your Vercel/GitHub repo settings (Project > Settings > Environment Variables)

NEXT_PUBLIC_SITE_URL= # Public site URL, e.g. https://lhotselab.com (used for canonical links and absolute URLs)
NEXT_PUBLIC_ANALYTICS_ID= # e.g. GA4 measurement ID or other public analytics identifier

# Server-side secret keys (add these to Vercel as PRODUCTION/Preview/Development env vars)
CF_API_TOKEN= # Cloudflare API token with Pages/DNS permissions (only if you automate DNS or Cloudflare APIs)
SENTRY_DSN= # Sentry DSN for error reporting
SMTP_URL= # SMTP connection string for emails (if used)

# Optional third-party integrations
SENDGRID_API_KEY= # SendGrid API key for transactional emails
NEXT_PUBLIC_MAPS_KEY= # Public maps key if using client-side mapping

# Notes:
# - Do not commit real secret values into the repository. Use your hosting provider's environment variables feature.
# - Vercel supports per-branch environment variables; set appropriately for Preview vs Production.
